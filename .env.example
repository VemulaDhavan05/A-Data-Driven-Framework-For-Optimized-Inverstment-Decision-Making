# WealthAI SMTP Configuration Template
# Rename this file to .env and fill in your credentials

# For Gmail: Use smtp.gmail.com and an "App Password" (NOT your regular password)
# For Outlook: Use smtp.office365.com and your email credentials

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
